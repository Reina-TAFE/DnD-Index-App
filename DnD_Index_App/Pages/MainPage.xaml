<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DnD_Index_App.MainPage"
             MaximumWidthRequest="400"
             MaximumHeightRequest="850">

    <ScrollView
        BackgroundColor="#582929"
>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <ImageButton 
                Margin="25 10 0"
                Grid.Row="0"
                x:Name="SettingsBtn"
                Source="settings_icon.png"
                Clicked="SettingsBtnClicked"
                VerticalOptions="Start"
                HorizontalOptions="Start"
                BackgroundColor="#582929"/>
            <Image
                Grid.Row="0"
                Source="logo_placeholder.png"
                HeightRequest="126"
                WidthRequest="126"
                Aspect="AspectFit"
                HorizontalOptions="Center"
                SemanticProperties.Description="Placeholder image for app icon" 
                Margin="50 0 20"/>

            <Button
                Grid.Row="1"
                x:Name="SpellsBtn"
                Text="Spells" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                HeightRequest="90"/>

            <Button
                Grid.Row="2"
                x:Name="ClassesBtn"
                Text="Classes" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                HeightRequest="90" />

            <Button
                Grid.Row="3"
                x:Name="EquipmentBtn"
                Text="Equipment" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                HeightRequest="90" />

            <Button
                Grid.Row="4"                
                x:Name="RulesBtn"
                Text="Rules" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                HeightRequest="90" />

            <Grid
                Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ImageButton
                Grid.Column="0"
                x:Name="NavSpellsBtn"
                Source="cleric_symbol.png"
                Padding="10"
                Opacity="65"                    
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                VerticalOptions="End"                    
                HeightRequest="90"/>

                <ImageButton
                Grid.Column="1"
                x:Name="NavClassesBtn"
                Source="paladin_symbol.png"
                Padding="10"
                Opacity="65"                    
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                VerticalOptions="End"
                HeightRequest="90" />

                <ImageButton
                Grid.Column="2"
                x:Name="NavEquipmentBtn"
                Source="fighter_symbol.png"
                Padding="10"
                Opacity="65"
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                VerticalOptions="End"                    
                HeightRequest="90" />

                <ImageButton
                Grid.Column="3"
                x:Name="NaveRulesBtn"
                Source="scroll.png"
                Padding="15"
                Opacity="65"                    
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill"
                VerticalOptions="End"                    
                HeightRequest="90"
                />
            </Grid>
        </Grid>
        
    </ScrollView>

</ContentPage>
