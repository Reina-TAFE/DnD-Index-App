<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DnD_Index_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DnD_Index_App"
    xmlns:pages="clr-namespace:DnD_Index_App.Pages"
    Title="DnD_Index_App">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate pages:MainPage}"
        Route="MainPage" />

    <ShellContent
    Title="Settings"
    Route="SettingsPage"/>

</Shell>
